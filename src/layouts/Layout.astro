---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="The Last Light Fades - Devblog" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div class="top-bar">
      <div>
        <a href="/register" class="clean-link">
          <button class="win-btn">🪟 кабинет</button>
        </a>
      </div>
      <div class="nav-buttons">
        <a href="/" class="clean-link"><button class="win-btn">главная</button></a>
        
        <a href="https://www.donationalerts.com/r/infa105" target="_blank" class="clean-link">
          <button class="win-btn btn-green">задонатить</button>
        </a>

        <!-- Новая кнопка YouTube -->
        <a href="https://www.youtube.com/@infa105" target="_blank" class="clean-link">
          <button class="win-btn btn-red">▶ YouTube</button>
        </a>
        
        <button class="win-btn">✈️ помощь</button>
        <button class="win-btn">ru ▼</button>
      </div>
    </div>
    
    <slot />
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    background-color: #000080; /* Классический синий фон */
    font-family: 'Tahoma', sans-serif;
    color: black;
    font-size: 16px; 
  }
  .top-bar {
    background-color: #c0c0c0;
    padding: 8px 15px; 
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #000; 
  }
  .nav-buttons {
    display: flex;
    gap: 8px; 
  }
  .clean-link {
    text-decoration: none;
  }
  
  /* НАСТОЯЩИЙ классический стиль кнопок Windows */
  .win-btn {
    background: #c0c0c0;
    border: 1px solid transparent;
    border-top-color: #ffffff;
    border-left-color: #ffffff;
    border-right-color: #000000;
    border-bottom-color: #000000;
    box-shadow: inset -1px -1px 0 #808080, inset 1px 1px 0 #dfdfdf;
    padding: 6px 16px;
    cursor: pointer;
    color: black;
    font-family: 'Tahoma', sans-serif;
    font-size: 14px;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .win-btn:active {
    border-top-color: #000000;
    border-left-color: #000000;
    border-right-color: #ffffff;
    border-bottom-color: #ffffff;
    box-shadow: inset 1px 1px 0 #808080, inset -1px -1px 0 #dfdfdf;
    padding: 7px 15px 5px 17px; /* Эффект смещения при нажатии */
  }
  
  .btn-green {
    background: #00ff00;
  }
  .btn-red {
    background: #ff0000;
    color: white; /* Чтобы текст на красном хорошо читался */
  }

  .desktop {
    padding: 30px;
  }
  .xp-window {
    background: #c0c0c0;
    border-top: 2px solid #fff;
    border-left: 2px solid #fff;
    border-bottom: 2px solid #000;
    border-right: 2px solid #000;
    box-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
  }
  .title-bar {
    background: linear-gradient(to right, #000080, #1084d0);
    color: white;
    padding: 4px 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: bold;
    font-size: 16px;
  }
  .controls {
    display: flex;
    gap: 3px;
  }
  .controls .win-btn {
    padding: 2px 6px;
    font-size: 12px;
    font-weight: normal;
  }
  
  /* Классические вдавленные поля ввода */
  .win-input {
    background: #ffffff;
    border: 1px solid transparent;
    border-top-color: #808080;
    border-left-color: #808080;
    border-right-color: #ffffff;
    border-bottom-color: #ffffff;
    box-shadow: inset 1px 1px 0 #000000;
    padding: 6px;
    font-size: 14px;
    font-family: 'Tahoma', sans-serif;
  }
</style>