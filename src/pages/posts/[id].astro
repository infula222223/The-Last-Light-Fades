---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - Девлог`}>
  <main class="desktop">
    <div class="xp-window large-window">
      <div class="title-bar">
        <span>{post.data.title}</span>
        <div class="controls">
          <a href="/" class="clean-link"><button class="win-btn">X</button></a>
        </div>
      </div>
      
      <div class="window-content retro-text">
        <article class="markdown-content">
          <Content />
        </article>
        
        <div class="comments-section">
          <div class="comments-header">
            <h3>Гостевая книга</h3>
          </div>

          <div id="comment-list" class="white-sunken-box">Загрузка сообщений...</div>

          <form id="comment-form" class="comment-form">
            <input type="text" id="name" placeholder="Ваш ник" required class="win-input" />
            <textarea id="text" placeholder="Текст сообщения..." required class="win-input" rows="2"></textarea>
            <button type="submit" class="win-btn">Отправить</button>
          </form>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ postId: post.id }}>
  const API = 'http://localhost:8000'; // Адрес твоего Python-сервера
  const list = document.getElementById('comment-list');
  const form = document.getElementById('comment-form');

  // Загрузка комментариев
  async function load() {
    try {
      const res = await fetch(`${API}/api/comments?postId=${postId}`);
      const data = await res.json();
      list.innerHTML = data.length 
        ? data.map(c => `<div class="comment-item"><b>${c.author}:</b> ${c.text}</div>`).join('')
        : '<p style="color:#666;">Пока сообщений нет.</p>';
    } catch (e) {
      list.innerHTML = '<p style="color:red;">Ошибка связи с БД.</p>';
    }
  }

  // Отправка комментария
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const author = document.getElementById('name').value;
    const text = document.getElementById('text').value;

    await fetch(`${API}/api/comments`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ postId, author, text })
    });
    
    document.getElementById('text').value = '';
    load();
  });

  load();
</script>

<style>
  .large-window { width: 800px; margin: 40px auto; background: #c0c0c0; border: 2px outset #fff; }
  .window-content { padding: 20px; }
  .retro-text { font-family: 'Tahoma', sans-serif; }
  
  .markdown-content { background: #fff; padding: 15px; border: 2px inset #fff; margin-bottom: 20px; }
  
  .comments-section { background: #ece9d8; padding: 15px; border: 2px outset #fff; }
  .white-sunken-box { background: #fff; border: 2px inset #fff; padding: 10px; height: 200px; overflow-y: auto; margin-bottom: 10px; }
  
  .comment-item { border-bottom: 1px solid #ccc; padding: 5px 0; font-size: 14px; }
  .comment-form { display: flex; flex-direction: column; gap: 5px; }
  .win-input { border: 1px solid #808080; padding: 4px; }
</style>