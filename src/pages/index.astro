---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
---

<Layout title="The Last Light Fades - Журнал разработки">
  <main class="desktop">
    <div class="xp-window">
      <div class="title-bar">
        <span>The Last Light Fades - Девлог.exe</span>
        <div class="controls">
          <button class="win-btn">_</button>
          <button class="win-btn">□</button>
          <button class="win-btn">X</button>
        </div>
      </div>
      
      <div class="window-content">
        <div class="header-info">
          <img src="https://win98icons.alexmeub.com/icons/png/computer_explorer-4.png" alt="Компьютер" width="48" height="48" class="pixel-icon">
          <div>
            <h2 class="retro-text">Журнал разработки</h2>
            <p class="retro-text sub-text">Следите за прогрессом создания игры.</p>
          </div>
        </div>

        <div class="white-box">
          {posts.length === 0 ? (
            <p class="retro-text empty-msg">Пока нет записей...</p>
          ) : (
            <ul class="post-list">
              {posts.map((post) => (
                <li class="post-item">
                  <a href={`/posts/${post.id}`} class="post-link retro-text">
                    {post.data.title}
                  </a>
                  <span class="retro-text date">
                    {post.data.date.toLocaleDateString('ru-RU')}
                  </span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .xp-window {
    width: 850px;
    max-width: 95%;
    margin: 60px auto;
    background: #c0c0c0;
    border: 2px outset #ffffff;
    padding: 2px;
  }

  .title-bar {
    background: linear-gradient(90deg, #000080, #1084d0);
    color: white;
    padding: 3px 5px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: bold;
    font-family: 'Tahoma', sans-serif;
  }

  .controls { display: flex; gap: 2px; }
  .win-btn { padding: 2px 8px; border: 2px outset #fff; background: #c0c0c0; cursor: pointer; }

  .window-content { padding: 20px; }
  .header-info { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; }
  .pixel-icon { image-rendering: pixelated; }

  .retro-text { font-family: 'MS Sans Serif', 'Tahoma', sans-serif; margin: 0; }
  .sub-text { font-size: 14px; margin-top: 5px; }

  .white-box {
    background: #ffffff;
    border: 2px inset #ffffff;
    height: 400px;
    overflow-y: auto;
    padding: 15px;
  }

  .post-list { list-style: none; padding: 0; margin: 0; }
  .post-item { border-bottom: 1px dotted #808080; padding: 10px 0; display: flex; justify-content: space-between; }
  
  .post-link { text-decoration: underline; color: #0000ff; font-weight: bold; font-size: 16px; }
  .post-link:hover { color: #ff0000; }
  
  .date { color: #808080; font-size: 14px; }
  .empty-msg { text-align: center; color: #808080; margin-top: 40px; }
</style>